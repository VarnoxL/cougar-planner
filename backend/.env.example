# Supabase PostgreSQL connection string
# Get from: Supabase dashboard → Settings → Database → Connection String → URI
# Use the Session Pooler (port 5432), NOT the Transaction Pooler (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Firebase service account JSON (single line, no newlines)
# Get from: Firebase console → Project Settings → Service Accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Your Vercel frontend URL (no trailing slash)
# Example: https://cougar-planner.vercel.app
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Current SIUE term code (e.g. 202635 = Summer 2026, 202640 = Fall 2026)
SIUE_TERM=202635
